{
  "name": "our-fridge",
  "private": true,
  "scripts": {
    "web": "pnpm --filter web dev",
    "mobile": "pnpm --filter mobile start",
    "mobile:android": "pnpm --filter mobile android",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter @our-fridge/api build",
    "build:shared": "pnpm --filter @our-fridge/shared build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "db:push": "supabase db execute --file supabase/schema.sql --project-ref exkzgbudslvmxblxwzmb",
    "android": "pnpm --filter mobile android",
    "ios": "pnpm --filter mobile ios"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "supabase": "^2.26.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.29.1+sha512.48dae233635a645768a3028d19545cacc1688639eeb1f3734e42d6d6b971afbf22aa1ac9af52a173d9c3a20c15857cfa400f19994d79a2f626fcc73fccda9bbc",
  "version": "1.0.0"
}
