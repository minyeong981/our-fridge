{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "projectRoot": "apps/mobile"
    },
    "preview": {
      "distribution": "internal",
      "projectRoot": "apps/mobile",
      "env": {
        "EXPO_PUBLIC_WEB_URL": "https://ourfridge.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "projectRoot": "apps/mobile",
      "env": {
        "EXPO_PUBLIC_WEB_URL": "https://ourfridge.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
