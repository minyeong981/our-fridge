{
  "expo": {
    "name": "우리의 냉장고",
    "slug": "our-fridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ourfridge",
    "icon": "./assets/images/our-fridge-icon.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/images/our-fridge-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ourfridge.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "유통기한 임박, 냉장고 초대, 댓글 알림을 받으려면 알림 권한이 필요해요."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/our-fridge-icon.png",
        "monochromeImage": "./assets/images/our-fridge-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ourfridge.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/our-fridge-icon.png",
          "color": "#4AB8CF",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/our-fridge-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/our-fridge-icon.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#1C1C1E"
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fb47d863-1cfa-4737-a716-6227ab7fb227"
      }
    }
  }
}
